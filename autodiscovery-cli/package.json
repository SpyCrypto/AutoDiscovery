{
  "name": "@autodiscovery/cli",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {      
    "test-undeployed": "vitest run discovery-core.test.ts",  
    "test-preview": "RUN_ENV_TESTS=true TEST_ENV=preview vitest run discovery-core.test.ts",
    "tui-undeployed": "npx tsx src/tui_standalone.ts",
    "tui-preview": "npx tsx src/tui_preview.ts",
    "setup-undeployed": "npx tsx src/setup/standalone.ts",
    "deploy-preprod": "npx tsx src/deploy_preprod.ts",
    "tui-preprod": "npx tsx src/tui_preview.ts", 
    "ps-undeployed": "docker compose -f ps-undeployed.yml up",
    "ps-preview": "docker compose -f ps-preview.yml up",
    "ps-preprod": "docker compose -f ps-preprod.yml up",               
    "build": "tsc --project tsconfig.build.json",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "private-provider-testing": "vitest run src/test/private-provider.test.ts",
    "public-provider-testing": "vitest run src/test/public-provider.test.ts",
    "zk-provider-testing": "vitest run src/test/zk-provider.test.ts",
    "indexer-client-testing": "vitest run src/test/indexer-client.test.ts",
    "wallet-testing": "vitest run src/test/wallet.test.ts"
  },
  "dependencies": {    
    "@autodiscovery/contract": "*"    
  }
}
